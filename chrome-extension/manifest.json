{
  "manifest_version": 3,
  "name": "ReviewIQ - Review Authenticity Analyzer",
  "short_name": "ReviewIQ",
  "version": "1.0.0",
  "description": "Analyze product reviews for authenticity, sentiment, and AI-generated content detection.",
  "homepage_url": "https://reviewiq.website",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://reviewiq.website/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.in/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.de/*",
        "*://*.amazon.fr/*",
        "*://*.amazon.it/*",
        "*://*.amazon.es/*",
        "*://*.amazon.com.au/*",
        "*://*.amazon.co.jp/*",
        "*://*.flipkart.com/*",
        "*://*.myntra.com/*",
        "*://*.ajio.com/*",
        "*://*.nykaa.com/*",
        "*://*.nykaafashion.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
