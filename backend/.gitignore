# =============================================================================
# Spring Boot Backend .gitignore
# =============================================================================

# ── Build Output ─────────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.factorypath
bin/
out/
.vscode/

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
*.pem
*.key
*.p12
*.jks

# ── Tests ────────────────────────────────────────────────────────────────────
src/test/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.gz
hs_err_pid*
replay_pid*

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
